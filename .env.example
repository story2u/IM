# Minimal VPS_ENV_FILE template for the receive-message stack.
# Copy this content into the GitHub Secret named VPS_ENV_FILE, then replace
# the placeholder value before deploying.

SESSION_JWT_SECRET=change-me-generate-a-long-random-secret
IM_DATABASE_URL=postgres://im:im-dev-password@go-postgres:5432/im?sslmode=disable
IM_AUTO_MIGRATE=true
IM_SEED_DATA=true

# Optional: set both when changing the bundled Postgres password.
# POSTGRES_PASSWORD=change-me-postgres-password
# IM_DATABASE_URL=postgres://im:change-me-postgres-password@go-postgres:5432/im?sslmode=disable
