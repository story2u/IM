{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://im-go/contracts/v1/agent-heartbeat.schema.json",
  "title": "AgentHeartbeat",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "devices", "timestamp"],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string"
    },
    "devices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["device_id", "online"],
        "properties": {
          "device_id": {
            "type": "string",
            "minLength": 1
          },
          "online": {
            "type": "boolean"
          },
          "model": {
            "type": "string"
          },
          "android_version": {
            "type": "string"
          },
          "last_error": {
            "type": "string"
          },
          "app_logged_in": {
            "type": "boolean"
          },
          "app_status": {
            "type": "string"
          },
          "wework_logged_in": {
            "type": "boolean"
          },
          "wework_status": {
            "type": "string"
          }
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string"
    }
  }
}
