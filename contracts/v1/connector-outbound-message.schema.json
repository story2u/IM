{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://im-go/contracts/v1/connector-outbound-message.schema.json",
  "title": "ConnectorOutboundMessage",
  "type": "object",
  "additionalProperties": false,
  "required": ["message_id", "idempotency_key", "connector_id", "channel", "tenant_id", "target", "conversation", "message_type", "created_at"],
  "properties": {
    "message_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string" },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "connector_id": { "type": "string", "minLength": 1 },
    "channel": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "account_id": { "type": "string" },
    "endpoint_id": { "type": "string" },
    "target": { "$ref": "#/$defs/contact_identity" },
    "conversation": { "$ref": "#/$defs/conversation_binding" },
    "message_type": {
      "type": "string",
      "enum": ["text", "image", "video", "voice", "file", "unknown"]
    },
    "content": { "type": "string" },
    "media": {
      "type": "array",
      "items": { "$ref": "#/$defs/media_attachment" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "contact_identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contact_id": { "type": "string" },
        "external_user_id": { "type": "string" },
        "display_name": { "type": "string" },
        "avatar_url": { "type": "string" },
        "remark": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "conversation_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conversation_id": { "type": "string" },
        "conversation_key": { "type": "string" },
        "external_conversation_id": { "type": "string" },
        "room_id": { "type": "string" },
        "type": { "type": "string", "enum": ["single", "group", "system", "unknown"] },
        "display_name": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "media_attachment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attachment_id": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "voice", "file", "unknown"] },
        "url": { "type": "string" },
        "object_key": { "type": "string" },
        "mime_type": { "type": "string" },
        "bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
