{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://im-go/contracts/v1/connector-delivery-receipt.schema.json",
  "title": "ConnectorDeliveryReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["receipt_id", "connector_id", "channel", "tenant_id", "message_id", "status", "occurred_at"],
  "properties": {
    "receipt_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string" },
    "connector_id": { "type": "string", "minLength": 1 },
    "channel": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "message_id": { "type": "string", "minLength": 1 },
    "connector_message_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["accepted", "sent", "delivered", "read", "failed", "revoked"]
    },
    "error_code": { "type": "string" },
    "error_message": { "type": "string" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
