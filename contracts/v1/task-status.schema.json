{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://im-go/contracts/v1/task-status.schema.json",
  "title": "TaskStatusEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "agent_id", "device_id", "status", "timestamp"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 8
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["accepted", "running", "success", "failed", "timeout", "cancelled"]
    },
    "message": {
      "type": "string"
    },
    "error_code": {
      "type": "string"
    },
    "result": {
      "type": "object"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string"
    }
  }
}
